# ---------------------------------------------------------------------------
# Environment variables for local development
# Copy this file to .env and fill in real values.
# ---------------------------------------------------------------------------

# Google Cloud project to use for Vertex AI (Gemini) calls
GOOGLE_CLOUD_PROJECT=cloudrun-mcp-agent

# Vertex AI region
GOOGLE_CLOUD_LOCATION=us-central1

# paper-search MCP server URL (Streamable HTTP endpoint)
MCP_SERVER_URL=https://paper-search-mcp-openai-v2--titansneaker.run.tools/mcp

# Smithery API key – used as the Bearer token for the MCP server
SMITHERY_API_KEY=YOUR_SMITHERY_API_KEY_HERE

# (Optional) Override if you want to run against a different port locally
# PORT=8080
